<Window x:Class="MdBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:vm="clr-namespace:MdBrowser.ViewModels"
        Title="Markdown Viewer"
        Icon="Assets/MdBrowser.ico"
        Width="1280" Height="800"
        MinWidth="720" MinHeight="480"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource WindowForeground}"
        FontFamily="{DynamicResource UiFont}"
        FontSize="{DynamicResource UiFontSize}"
        WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">

        <!-- ============ Top toolbar (Crust) ============ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource CtpCrust}"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,16,0">
                    <TextBlock Text="◆"
                               Foreground="{DynamicResource CtpMauve}"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Markdown Viewer"
                               Foreground="{DynamicResource CtpText}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Open folder…"
                            Style="{StaticResource AccentButton}"
                            Margin="0,0,8,0"
                            Command="{Binding OpenFolderCommand}"/>
                    <Button Content="Refresh"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding RefreshCommand}"/>
                    <Button Content="Save (Ctrl+S)"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding SaveCommand}"
                            Margin="8,0,0,0"
                            ToolTip="Save the editor contents back to the file"/>
                </StackPanel>

                <!-- Current path -->
                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentFolderPath}"
                           Foreground="{DynamicResource CtpSubtext0}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="20,0"/>

                <!-- Filter toggle + editor layout + theme picker -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Markdown only"
                              IsChecked="{Binding MarkdownOnly, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="0,0,16,0"/>
                    <TextBlock Text="Editor:"
                               Foreground="{DynamicResource CtpSubtext0}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <ComboBox x:Name="EditorLayoutPicker"
                              SelectionChanged="EditorLayoutPicker_SelectionChanged"
                              VerticalAlignment="Center"
                              Width="100"
                              Margin="0,0,16,0"
                              ToolTip="Move or hide the editor pane (Ctrl+E to toggle)"/>
                    <TextBlock Text="Theme:"
                               Foreground="{DynamicResource CtpSubtext0}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <ComboBox x:Name="ThemePicker"
                              SelectionChanged="ThemePicker_SelectionChanged"
                              VerticalAlignment="Center"
                              Width="160"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ Status bar (Mantle) ============ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource CtpMantle}"
                Padding="12,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           x:Name="ThemeLabel"
                           Text="Catppuccin Mocha"
                           Foreground="{DynamicResource CtpOverlay1}"
                           FontSize="11"/>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource CtpSubtext0}"
                           FontSize="11"/>
            </DockPanel>
        </Border>

        <!-- ============ Main split: TreeView | Preview ============ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left pane: file tree (Mantle) -->
            <Border Grid.Column="0" Background="{DynamicResource CtpMantle}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource CtpMantle}"
                            Padding="12,10,12,6">
                        <TextBlock Text="EXPLORER"
                                   Foreground="{DynamicResource CtpSubtext0}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <TreeView x:Name="FolderTree"
                              ItemsSource="{Binding Root.Children}"
                              SelectedItemChanged="FolderTree_SelectedItemChanged"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:FileNodeViewModel}"
                                                     ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="{DynamicResource CtpBlue}"
                                               FontSize="14"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Splitter (Crust hairline) -->
            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Right pane: Preview + Editor. Row/Column setup is driven by code-behind
                 (ApplyEditorLayout) so the editor can be docked to any side or hidden. -->
            <Grid x:Name="PreviewEditorGrid" Grid.Column="2" Background="{DynamicResource CtpBase}">

                <!-- Preview -->
                <wv2:WebView2 x:Name="Preview"
                              DefaultBackgroundColor="#1E1E2E"/>

                <!-- Splitter between preview and editor -->
                <GridSplitter x:Name="EditorSplitter"
                              ResizeBehavior="PreviousAndNext"/>

                <!-- Editor area -->
                <DockPanel x:Name="EditorPane" Background="{DynamicResource CtpBase}">

                    <!-- Editor header bar -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource CtpMantle}"
                            Padding="12,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="SOURCE"
                                       Foreground="{DynamicResource CtpSubtext0}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="EditorTitle"
                                       Text=""
                                       Foreground="{DynamicResource CtpSubtext1}"
                                       FontSize="11"
                                       Margin="16,0,0,0"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2"
                                       Text="● modified"
                                       x:Name="DirtyIndicator"
                                       Foreground="{DynamicResource CtpYellow}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Markdown formatting toolbar -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource CtpMantle}"
                            BorderBrush="{DynamicResource CtpSurface0}"
                            BorderThickness="0,1,0,0"
                            Padding="6,4">
                        <WrapPanel x:Name="EditorToolbar"
                                   IsEnabled="{Binding ElementName=Editor, Path=IsEnabled}">
                            <!-- Headings -->
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" MinWidth="32" Margin="0,0,2,2"
                                    Click="MdBtn_Heading1_Click" ToolTip="Heading 1">
                                <TextBlock Text="H1" FontWeight="SemiBold"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" MinWidth="32" Margin="0,0,2,2"
                                    Click="MdBtn_Heading2_Click" ToolTip="Heading 2">
                                <TextBlock Text="H2" FontWeight="SemiBold"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" MinWidth="32" Margin="0,0,10,2"
                                    Click="MdBtn_Heading3_Click" ToolTip="Heading 3">
                                <TextBlock Text="H3" FontWeight="SemiBold"/>
                            </Button>

                            <!-- Inline formatting -->
                            <Button Style="{StaticResource ToolbarButton}" Padding="8,2" MinWidth="28" Margin="0,0,2,2"
                                    Click="MdBtn_Bold_Click" ToolTip="Bold (Ctrl+B)">
                                <TextBlock Text="B" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="8,2" MinWidth="28" Margin="0,0,2,2"
                                    Click="MdBtn_Italic_Click" ToolTip="Italic (Ctrl+I)">
                                <TextBlock Text="I" FontStyle="Italic"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="8,2" MinWidth="28" Margin="0,0,2,2"
                                    Click="MdBtn_Strike_Click" ToolTip="Strikethrough">
                                <TextBlock Text="S" TextDecorations="Strikethrough"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" MinWidth="32" Margin="0,0,10,2"
                                    Click="MdBtn_InlineCode_Click" ToolTip="Inline code">
                                <TextBlock Text="&lt;/&gt;" FontFamily="Cascadia Code, Consolas"/>
                            </Button>

                            <!-- Links / images -->
                            <Button Style="{StaticResource ToolbarButton}" Padding="8,2" Margin="0,0,2,2"
                                    Click="MdBtn_Link_Click" ToolTip="Insert link (Ctrl+K)">
                                <TextBlock Text="Link"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="8,2" Margin="0,0,10,2"
                                    Click="MdBtn_Image_Click" ToolTip="Insert image…">
                                <TextBlock Text="Image"/>
                            </Button>

                            <!-- Lists -->
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" Margin="0,0,2,2"
                                    Click="MdBtn_BulletList_Click" ToolTip="Bullet list">
                                <TextBlock Text="• List"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" Margin="0,0,2,2"
                                    Click="MdBtn_NumberedList_Click" ToolTip="Numbered list">
                                <TextBlock Text="1. List"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" Margin="0,0,10,2"
                                    Click="MdBtn_TaskList_Click" ToolTip="Task list">
                                <TextBlock Text="☐ Task"/>
                            </Button>

                            <!-- Blocks -->
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" Margin="0,0,2,2"
                                    Click="MdBtn_Quote_Click" ToolTip="Block quote">
                                <TextBlock Text="❝ Quote"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" Margin="0,0,2,2"
                                    Click="MdBtn_CodeBlock_Click" ToolTip="Fenced code block">
                                <TextBlock Text="{} Code"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" Margin="0,0,2,2"
                                    Click="MdBtn_Table_Click" ToolTip="Insert table">
                                <TextBlock Text="▦ Table"/>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Padding="6,2" Margin="0,0,2,2"
                                    Click="MdBtn_HorizontalRule_Click" ToolTip="Horizontal rule">
                                <TextBlock Text="— HR"/>
                            </Button>
                        </WrapPanel>
                    </Border>

                    <!-- Issues panel (bottom) -->
                    <Border DockPanel.Dock="Bottom"
                            Background="{DynamicResource CtpMantle}"
                            BorderBrush="{DynamicResource CtpSurface0}"
                            BorderThickness="0,1,0,0"
                            MaxHeight="160">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Background="{DynamicResource CtpMantle}"
                                    Padding="12,5">
                                <TextBlock Text="{Binding IssuesSummary}"
                                           Foreground="{DynamicResource CtpSubtext0}"
                                           FontSize="11"/>
                            </Border>
                            <ListBox x:Name="IssuesList"
                                     Background="{DynamicResource CtpMantle}"
                                     Foreground="{DynamicResource CtpText}"
                                     BorderThickness="0"
                                     MouseDoubleClick="IssuesList_MouseDoubleClick"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource CtpText}"/>
                                        <Setter Property="Padding" Value="12,3"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CtpSurface0}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CtpSurface1}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Glyph}"
                                                       Width="16"
                                                       FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource CtpSubtext0}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                                <Setter Property="Foreground" Value="{DynamicResource CtpRed}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                <Setter Property="Foreground" Value="{DynamicResource CtpYellow}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Info">
                                                                <Setter Property="Foreground" Value="{DynamicResource CtpBlue}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Line, StringFormat='Line {0}:'}"
                                                       Foreground="{DynamicResource CtpSubtext0}"
                                                       Width="74"
                                                       Margin="4,0,8,0"/>
                                            <TextBlock Text="{Binding Message}"
                                                       Foreground="{DynamicResource CtpText}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- AvalonEdit -->
                    <ae:TextEditor x:Name="Editor"
                                   FontFamily="Cascadia Code, JetBrains Mono, Consolas"
                                   FontSize="13"
                                   ShowLineNumbers="True"
                                   WordWrap="True"
                                   Background="{DynamicResource CtpBase}"
                                   Foreground="{DynamicResource CtpText}"
                                   LineNumbersForeground="{DynamicResource CtpOverlay0}"
                                   Padding="6,6"
                                   IsEnabled="False"/>
                </DockPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
